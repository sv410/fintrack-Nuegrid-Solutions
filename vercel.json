{
  "version": 2,
  "installCommand": "pnpm install",
  "buildCommand": "BASE_PATH=/ pnpm --filter @workspace/finance-dashboard run build",
  "functions": {
    "api/handler.ts": {
      "maxDuration": 30,
      "memory": 512
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/handler.ts" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
